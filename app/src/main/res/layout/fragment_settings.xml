<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Work Hours -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="8dp"
            android:text="@string/settings_section_hours"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="4dp"
            android:text="@string/work_start_label" />

        <Button
            android:id="@+id/btnWorkStart"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="08:00" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="4dp"
            android:paddingTop="12dp"
            android:text="@string/work_end_label" />

        <Button
            android:id="@+id/btnWorkEnd"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="18:00" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="4dp"
            android:paddingTop="12dp"
            android:text="@string/gps_interval_label" />

        <EditText
            android:id="@+id/etGpsInterval"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:hint="@string/minutes_hint"
            android:inputType="number" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="4dp"
            android:text="@string/gps_interval_hint"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary" />

        <!-- Attendance Target -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="8dp"
            android:paddingTop="24dp"
            android:text="@string/settings_section_target"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTargetValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingBottom="8dp"
            android:textSize="36sp"
            android:textStyle="bold" />

        <SeekBar
            android:id="@+id/seekBarTarget"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Fiscal Quarter -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="8dp"
            android:paddingTop="24dp"
            android:text="@string/settings_section_quarter"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="4dp"
            android:text="@string/settings_quarter_warning"
            android:textColor="@color/design_default_color_error" />

        <RadioGroup
            android:id="@+id/rgPreset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RadioButton
                android:id="@+id/rbCalendar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="@string/preset_calendar" />

            <RadioButton
                android:id="@+id/rbFebStart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/preset_feb_start" />

            <RadioButton
                android:id="@+id/rbAprStart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/preset_apr_start" />

            <RadioButton
                android:id="@+id/rbMayStart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/preset_may_start" />

            <RadioButton
                android:id="@+id/rbCustom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/preset_custom" />

        </RadioGroup>

        <LinearLayout
            android:id="@+id/layoutCustomMonth"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="8dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/start_month_label" />

            <NumberPicker
                android:id="@+id/pickerMonth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <!-- Offices -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="8dp"
            android:paddingTop="24dp"
            android:text="@string/settings_section_offices"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnManageOffices"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_manage_offices" />

        <!-- Debug -->
        <CheckBox
            android:id="@+id/cbDebugMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/settings_debug_mode" />

        <LinearLayout
            android:id="@+id/layoutDebug"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:visibility="gone">

            <Button
                android:id="@+id/btnCheckGpsNow"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_check_gps_now" />

            <TextView
                android:id="@+id/tvLastRejection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:paddingTop="8dp"
                android:textColor="@color/design_default_color_error" />

            <TextView
                android:id="@+id/tvNextFix"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:paddingTop="8dp" />

            <TextView
                android:id="@+id/tvFix0"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:paddingTop="8dp" />

            <TextView
                android:id="@+id/tvFix1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:paddingTop="2dp" />

            <TextView
                android:id="@+id/tvFix2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:paddingTop="2dp" />

        </LinearLayout>

        <!-- Save -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/settings_save" />

    </LinearLayout>
</ScrollView>
