<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="8dp"
        android:text="@string/step6_title"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="16dp"
        android:text="@string/step6_subtitle" />

    <RadioGroup
        android:id="@+id/rgPreload"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <RadioButton
            android:id="@+id/rbNoPreload"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="@string/preload_no" />

        <RadioButton
            android:id="@+id/rbYesPreload"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/preload_yes" />

    </RadioGroup>

    <LinearLayout
        android:id="@+id/layoutCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="12dp"
        android:visibility="gone">

        <EditText
            android:id="@+id/etCount"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:hint="@string/preload_count_hint"
            android:inputType="number" />

    </LinearLayout>

</LinearLayout>
